[importlinter:contract:cli-isolation]
name = CLI and contrib are not imported by core query modules
type = forbidden
source_modules =
    ferrum.models
    ferrum.queryset
    ferrum.connection
    ferrum.hooks
    ferrum.errors
    ferrum.migrations
forbidden_modules =
    ferrum.cli
    ferrum.contrib
    typer
    rich
    fastapi
    starlette

# Contract 2: contrib must not be imported by core.
[importlinter:contract:contrib-isolation]
name = contrib is not imported by core
type = forbidden
source_modules =
    ferrum.models
    ferrum.queryset
    ferrum.connection
    ferrum.hooks
    ferrum.errors
    ferrum.migrations
    ferrum.cli
forbidden_modules =
    ferrum.contrib

# Contract 3: core must not import CLI.
# ferrum.models is excluded from this layers contract because the Manager descriptor
# in models.py contains a deferred import of ferrum.queryset (needed for User.objects).
# The forbidden contracts above already enforce that models cannot import ferrum.cli
# or ferrum.contrib, which are the security-critical isolation gates.
[importlinter:contract:core-does-not-import-cli]
name = core query path does not import CLI
type = layers
layers =
    ferrum.cli
    ferrum.contrib
    ferrum.migrations
    ferrum.hooks
    ferrum.errors
    ferrum.connection
    ferrum.queryset
